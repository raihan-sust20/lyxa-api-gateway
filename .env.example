# Application
NODE_ENV=development
PORT=5001
API_PREFIX=api

# JWT
JWT_ACCESS_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRES_IN=900
JWT_REFRESH_EXPIRES_IN=604800

# gRPC - Auth Service
AUTH_GRPC_URL=localhost:50051

# gRPC - Product Service
PRODUCT_GRPC_URL=localhost:50053
